# Copy to `.env.local` for local development. Never commit `.env.local`.

# Application environment (`development` shows dev-only UI such as Simulate purchase panel)
ENV=development

# Must match the Nest API origin (see server `PORT`; e.g. http://localhost:4400)
NEXT_PUBLIC_API_URL=http://localhost:4400

# Clerk (same instance as server `CLERK_SECRET_KEY`)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=KIKBACK

# Optional: match server REFERRAL_* so “Simulate purchase” can preview points (dev only)
# NEXT_PUBLIC_REFERRAL_POINTS_PER_DOLLAR=
# NEXT_PUBLIC_REFERRAL_REWARD_BPS=1500
# NEXT_PUBLIC_REFERRAL_REWARD_POINTS_PER_ORDER=100
