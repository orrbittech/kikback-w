# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules/

/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — secrets stay local; templates like .env.example may be committed
.env*
!.env.example
!.env.sample
!.env*.example

# keys & certs
*.pfx
*.p12

# Playwright (e2e)
/playwright-report/
/test-results/


# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
